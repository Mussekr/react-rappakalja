{
    "name": "rappakalja",
    "version": "2.0.0",
    "description": "Help tool for the Rappakalja board game",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:server": "nodemon --env-file=.env server/server.js",
        "build": "vite build",
        "start": "node server/server.js",
        "postinstall": "vite build",
        "lint": "eslint src/ server/",
        "migrate": "db-migrate",
        "prod-migrate": "npm run migrate -- up -e prod",
        "fly:deploy": "fly deploy",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "author": "Rasmus Kröger",
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cookie": "^1.1.1",
        "cookie-parser": "^1.4.7",
        "db-migrate": "^0.11.14",
        "db-migrate-pg": "^1.5.2",
        "express": "^5.1.0",
        "jose": "^6.2.1",
        "lucide-react": "^0.577.0",
        "openai": "^6.33.0",
        "pg-promise": "^11.10.2",
        "randomatic": "^3.1.1",
        "socket.io": "^4.8.3",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.18.0",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.1.0",
        "globals": "^15.14.0",
        "jsdom": "^28.1.0",
        "nodemon": "^3.1.9",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^6.28.2",
        "socket.io-client": "^4.8.3",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.2.1",
        "vite": "^6.0.9",
        "vitest": "^4.1.0"
    }
}
